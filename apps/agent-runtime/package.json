{
  "name": "@taskora/agent-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/run-with-root-env.mjs tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node ../../scripts/run-with-root-env.mjs node dist/index.js",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@taskora/agent-sdk": "workspace:*",
    "@taskora/core": "workspace:*",
    "@taskora/gensyn": "workspace:*",
    "@taskora/keeperhub": "workspace:*",
    "@taskora/og": "workspace:*",
    "@taskora/supabase": "workspace:*",
    "fastify": "^5.3.2",
    "zod": "^3.24.3"
  }
}
